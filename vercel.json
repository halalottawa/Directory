{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "https://ais-pre-o3grau7ukgun6nvnjrynhh-118138859761.us-east5.run.app/favicon.ico" },
    { "source": "/favicon.svg", "destination": "https://ais-pre-o3grau7ukgun6nvnjrynhh-118138859761.us-east5.run.app/favicon.svg" },
    { "source": "/api/(.*)", "destination": "https://ais-pre-o3grau7ukgun6nvnjrynhh-118138859761.us-east5.run.app/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://ais-pre-o3grau7ukgun6nvnjrynhh-118138859761.us-east5.run.app/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
